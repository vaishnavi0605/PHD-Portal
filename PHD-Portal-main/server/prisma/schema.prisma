generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  isAdmin     Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Application Application?

  @@map("users")
}

model Application {
  id               String       @id @default(cuid())
  user_id          String       @unique
  user             User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  first_name       String?
  last_name        String?
  gender           String?
  email            String?
  name             String
  dob              DateTime?
  category         String?
  marital_status   String?
  nationality      String?      @default("Indian")
  research_area    String?
  research_pref_1  String?
  research_pref_2  String?
  study_mode       String?
  address          String?
  phone            String?
  declaration_accepted Boolean   @default(false)
  nbhm_eligible    Boolean      @default(false)
  eligibility_status  String?
  eligibility_message String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @default(now())

  education        Education[]
  exam_scores      ExamScore[]

  @@map("applications")
}

model Education {
  id             Int         @id @default(autoincrement())
  application_id String
  level          String
  board          String?
  degree_name    String?
  custom_degree_name String?
  cfti_status    String?
  discipline     String?
  institute      String?
  study_type     String?
  year           Int?
  year_of_passing Int?
  score_type     String?     // 'percentage' or 'cgpa'
  score_value    Float?      // The actual value (0-100 for %, 0-10 for CGPA)
  division       String?

  application    Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@map("education")
}

model ExamScore {
  id             Int         @id @default(autoincrement())
  application_id String
  exam_type      String
  exam_name      String?
  custom_exam_name String?
  branch         String?
  year           Int?
  valid_upto     String?     // e.g. "March 2026"
  percentile     Float?
  rank           Int?
  score          Float?
  air            Int?        // All India Rank (GATE only)
  duration       String?     // e.g. "JRF" or "SRF" (CSIR only)

  application    Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@map("exam_scores")
}

model OneTimePassword {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("otps")
}
